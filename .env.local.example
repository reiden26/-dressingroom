# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL and anon key — found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Replicate ────────────────────────────────────────────────────────────────
# Get your token at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_token_here

# ─── Sentry ───────────────────────────────────────────────────────────────────
# Get your DSN at: https://sentry.io → Project → Settings → Client Keys
# Leave empty to disable error tracking (safe for local development)
NEXT_PUBLIC_SENTRY_DSN=
# Required only for production builds (uploading source maps)
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
SENTRY_AUTH_TOKEN=your-auth-token
